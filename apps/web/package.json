{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:standalone": "cross-env STANDALONE_BUILD=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "rebuild": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@repo/config": "workspace:^",
    "@repo/database": "workspace:^",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.24.0",
    "next": "^15.3.3",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^22.3.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
