# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Prime Accessories Kenya"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret-at-least-32-chars

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://prime_accessories_kenya:prime_accessories_kenya@localhost:5432/prime_accessories_kenya?schema=public

# Payments — optional in dev (set PAYMENT_DEV_MODE=true to simulate)
PAYMENT_DEV_MODE=true

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# M-Pesa Daraja (https://developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
